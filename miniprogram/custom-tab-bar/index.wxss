.tabbar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 110rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f2f5;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
}

.item {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  color: #6b7785;
}

.item.active {
  color: #1677ff;
  font-weight: 700;
}

.text {
  font-size: 26rpx;
}
