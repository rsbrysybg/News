.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.field {
  margin-top: 18rpx;
}

.label {
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.input {
  background: #f0f2f5;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
}

.actions {
  margin-top: 18rpx;
  display: flex;
  justify-content: flex-end;
}

.row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.right-actions {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}

.right-actions button {
  margin: 0;
  width: auto;
}

.btn-mini {
  padding: 12rpx 18rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
}

.btn-danger {
  background: #ffffff;
  color: #ff4d4f;
  border: 2rpx solid #ff4d4f;
  border-radius: 12rpx;
  padding: 12rpx 18rpx;
  font-size: 24rpx;
}

.left {
  flex: 1;
  min-width: 0;
}

.name {
  font-size: 28rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}


.meta-line {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 10rpx;
  margin-top: 8rpx;
}

.badge {
  font-size: 22rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #f0f2f5;
  color: #6b7785;
}

.badge-on {
  background: #e6f4ff;
  color: #1677ff;
}

.badge-off {
  background: #fff1f0;
  color: #cf1322;
}

.footer {
  text-align: center;
  padding: 18rpx 0;
}
