<view class="container">
  <view class="card">
    <view class="section-title">新增栏目</view>

    <view class="field">
      <view class="label">名称</view>
      <input class="input" value="{{form.name}}" placeholder="如：科技" bindinput="onInput" data-k="name" />
    </view>

    <view class="field">
      <view class="label">排序(数字越小越靠前)</view>
      <input class="input" type="number" value="{{form.sort}}" placeholder="0" bindinput="onInput" data-k="sort" />
    </view>

    <view class="actions">
      <button class="btn-primary" loading="{{saving}}" bindtap="onSave">保存</button>
    </view>
  </view>

  <view class="card" style="margin-top: 18rpx;">
    <view class="section-title">栏目列表</view>

    <block wx:for="{{list}}" wx:key="_id">
      <view class="row">
        <view class="left">
          <view class="name">{{item.name}}</view>
          <view class="meta-line">
            <view class="badge">sort {{item.sort}}</view>
            <view class="badge {{item.isActive ? 'badge-on' : 'badge-off'}}">{{item.isActive ? '启用' : '停用'}}</view>
          </view>
        </view>
        <view class="right-actions">
          <button
            class="btn-mini {{item.isActive ? 'btn-plain' : 'btn-primary'}}"
            data-id="{{item._id}}"
            data-active="{{item.isActive}}"
            bindtap="toggleActive"
          >
            {{item.isActive ? '停用' : '启用'}}
          </button>
          <button class="btn-mini btn-danger" data-id="{{item._id}}" data-name="{{item.name}}" bindtap="onDelete">删除</button>
        </view>
      </view>
    </block>

    <view wx:if="{{loading}}" class="muted footer">加载中...</view>
    <view wx:elif="{{!loading && list.length===0}}" class="muted footer">暂无栏目</view>
  </view>
</view>
