.section-title {
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.seg {
  display: flex;
  flex-direction: row;
  background: #f0f2f5;
  border-radius: 12rpx;
  padding: 8rpx;
}

.seg-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  border-radius: 10rpx;
  color: #6b7785;
}

.seg-active {
  background: #ffffff;
  color: #1677ff;
  font-weight: 700;
}

.field {
  margin-top: 18rpx;
}

.label {
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.input {
  background: #f0f2f5;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
}

.textarea {
  background: #f0f2f5;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
  min-height: 140rpx;
}

.textarea.content {
  min-height: 260rpx;
}

.picker {
  background: #f0f2f5;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
}

.cover-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.cover {
  width: 160rpx;
  height: 120rpx;
  border-radius: 12rpx;
  background: #f0f2f5;
  margin-right: 12rpx;
}

.actions {
  margin-top: 22rpx;
  display: flex;
  flex-direction: row;
}

.actions button {
  margin-right: 12rpx;
}

.news-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.news-main {
  flex: 1;
  padding-right: 12rpx;
}

.news-title {
  font-size: 28rpx;
  font-weight: 600;
}

.news-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
}

.dot {
  margin: 0 10rpx;
}

.footer {
  text-align: center;
  padding: 18rpx 0;
}
