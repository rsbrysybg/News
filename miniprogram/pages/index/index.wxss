.search-input {
  background: #f0f2f5;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
}

.top-swiper {
  width: 100%;
  height: 280rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 18rpx;
  background: #f0f2f5;
}

.top-swiper-item {
  width: 100%;
  height: 100%;
  position: relative;
}

.top-img {
  width: 100%;
  height: 100%;
}

.top-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 120rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.55));
}

.top-title {
  position: absolute;
  left: 18rpx;
  right: 18rpx;
  bottom: 16rpx;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tabs {
  margin-top: 16rpx;
  white-space: nowrap;
}

.tabs-inner {
  display: flex;
  flex-direction: row;
}

.tab {
  padding: 16rpx 18rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: #f6f7f9;
  font-size: 26rpx;
}

.tab-active {
  background: #1677ff;
  color: #ffffff;
}

.list {
  margin-top: 18rpx;
}

.item {
  display: flex;
  flex-direction: row;
  align-items: stretch;
  margin-bottom: 18rpx;
}

.item-left {
  flex: 1;
  padding-right: 18rpx;
}

.item-title {
  font-size: 32rpx;
  font-weight: 600;
}

.item-sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.item-meta {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.dot {
  margin: 0 10rpx;
}

.item-img {
  width: 200rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: #f0f2f5;
}

.footer {
  text-align: center;
  padding: 24rpx 0 40rpx;
}
