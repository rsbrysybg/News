.title {
  font-size: 38rpx;
  font-weight: 700;
}

.meta {
  margin-top: 10rpx;
  font-size: 24rpx;
}

.dot {
  margin: 0 10rpx;
}

.cover {
  margin-top: 18rpx;
  width: 100%;
  height: 360rpx;
  border-radius: 16rpx;
  background: #f0f2f5;
}

.content {
  margin-top: 18rpx;
  line-height: 1.7;
}

.actions {
  margin-top: 18rpx;
  display: flex;
  justify-content: flex-end;
}

.comments {
  margin-top: 18rpx;
  padding-bottom: 120rpx;
}

.comments-title {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 18rpx;
}

.comment {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.comment-head {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #f0f2f5;
  margin-right: 12rpx;
}

.comment-name {
  font-size: 26rpx;
  font-weight: 600;
}

.comment-time {
  margin-left: auto;
  font-size: 22rpx;
}

.comment-body {
  margin-top: 10rpx;
  font-size: 28rpx;
}

.footer {
  text-align: center;
  padding: 18rpx 0;
}

.comment-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 16rpx;
  background: #ffffff;
  border-top: 1rpx solid #f0f2f5;
}

.comment-input {
  flex: 1;
  background: #f0f2f5;
  border-radius: 12rpx;
  padding: 18rpx 20rpx;
  font-size: 28rpx;
}

.send {
  margin-left: 12rpx;
  padding: 18rpx 22rpx;
}
