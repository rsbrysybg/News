<view class="container tabbar-safe-bottom">
  <view class="card profile">
    <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
    <view class="right">
      <view class="name">{{userInfo.nickName}}</view>
      <view class="muted sub">openid: {{openidShort}}</view>
    </view>
    <button wx:if="{{!hasLogin}}" class="btn-plain" bindtap="onLogin">登录</button>
  </view>

  <view class="card">
    <view class="section-title">数据初始化</view>
    <view class="muted" style="font-size: 24rpx;">用于联调演示：如果 news 已有数据会自动跳过</view>
    <button class="btn-primary" style="margin-top: 14rpx;" bindtap="onInitDemoData">一键初始化示例数据</button>
  </view>

  <view class="card">
    <view class="section-title">我的收藏</view>
    <block wx:for="{{favorites}}" wx:key="_id">
      <view class="fav-item" data-id="{{item.newsId}}" bindtap="goDetail">
        <view class="fav-title">{{item.title}}</view>
        <view class="muted fav-time">{{item.createTimeText}}</view>
      </view>
    </block>
    <view wx:if="{{loadingFav}}" class="muted footer">加载中...</view>
    <view wx:elif="{{!loadingFav && favorites.length===0}}" class="muted footer">暂无收藏</view>
  </view>

  <view wx:if="{{isAdmin}}" class="card admin">
    <view class="section-title">管理员</view>
    <view class="admin-actions">
      <button class="btn-primary" bindtap="goPublish">发布/编辑新闻</button>
      <button class="btn-plain" bindtap="goAdminComments">评论审核</button>
      <button class="btn-plain" bindtap="goAdminCategory">栏目管理</button>
    </view>
  </view>
</view>
